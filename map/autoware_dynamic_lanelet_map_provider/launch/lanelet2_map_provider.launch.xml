<launch>
  <arg name="param_path" default="$(find-pkg-share autoware_dynamic_lanelet_map_provider)/config/lanelet2_map_provider.param.yaml"/>
  <arg name="input_odometry" default="/localization/kinematic_state"/>
  <arg name="input_lanelet2_map_metadata" default="/map/output/lanelet2_map_metadata"/>
  <arg name="output_lanelet2_submap" default="output/lanelet2_submap"/>
  <arg name="service_get_selected_lanelet2_map" default="/map/service/get_selected_lanelet2_map"/>

  <node pkg="autoware_dynamic_lanelet_map_provider" exec="autoware_lanelet2_map_provider" name="lanelet2_map_provider" output="both">
    <param from="$(var param_path)"/>
    <remap from="input/odometry" to="$(var input_odometry)"/>
    <remap from="input/lanelet2_map_metadata" to="$(var input_lanelet2_map_metadata)"/>
    <remap from="output/lanelet2_submap" to="$(var output_lanelet2_submap)"/>
    <remap from="service/get_selected_lanelet2_map" to="$(var service_get_selected_lanelet2_map)"/>
  </node>

  <node pkg="autoware_lanelet2_map_visualizer" exec="autoware_lanelet2_map_visualizer" name="lanelet2_map_visualization" output="both">
    <remap from="input/lanelet2_map" to="$(var output_lanelet2_submap)"/>
    <remap from="output/lanelet2_map_marker" to="output/lanelet2_submap_marker"/>
  </node>
</launch>
